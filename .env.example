# ─── Backend (FastAPI) ────────────────────────────────────────────────
#
# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
LEMBERG_SECRET_KEY=

# Comma-separated allow-list. Use "*" only for local dev (it disables
# credentialed CORS automatically).
LEMBERG_CORS_ORIGINS=https://lemberg.example.com,https://www.lemberg.example.com

# SQLAlchemy URL. Defaults to a local SQLite file if unset.
# Postgres example: postgresql+psycopg://user:pass@host:5432/lemberg
LEMBERG_DATABASE_URL=sqlite:///./cms.db

# Upload cap (bytes). Default 20 MiB. Increase for raw camera files.
LEMBERG_UPLOAD_MAX_BYTES=20971520

# JWT access-token lifetime in minutes. Default 60.
LEMBERG_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Standard Python logging level (DEBUG / INFO / WARNING / ERROR).
LEMBERG_LOG_LEVEL=INFO

# Expose /docs, /redoc, /openapi.json. ON by default for dev convenience —
# disable in production so the schema isn't broadcast publicly.
LEMBERG_DOCS_ENABLED=false

# Version string returned by /api/version. Useful for cache-busting and
# checking what's deployed.
LEMBERG_VERSION=1.3.0


# ─── Frontend (Vite) ──────────────────────────────────────────────────
#
# These are baked in at build time. After editing, re-run `npm run build`.
VITE_API_URL=https://api.lemberg.example.com/api
VITE_ASSET_BASE=https://api.lemberg.example.com
